    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Defino los parámetros físicos del experimento\n",
    "slit_distance  = 0.0001   # distancia entre las dos rendijas (0.1 mm en metros)\n",
    "wavelength     = 500e-9   # longitud de onda de la luz (500 nm, luz verde)\n",
    "screen_distance = 1.0     # distancia de las rendijas a la pantalla (1 metro)\n",
    "screen_width   = 0.05     # ancho de la pantalla (5 cm)\n",
    "num_points     = 1000     # cantidad de puntos donde calculo la intensidad\n",
    "\n",
    "# Creo un array de puntos a lo largo de la pantalla\n",
    "screen_points = np.linspace(-screen_width / 2, screen_width / 2, num_points)\n",
    "\n",
    "# Posición de cada rendija (una arriba y una abajo del centro)\n",
    "slit_A = -slit_distance / 2\n",
    "slit_B =  slit_distance / 2\n",
    "\n",
    "# Calculo la distancia de cada rendija a cada punto de la pantalla\n",
    "# Uso Pitágoras: d = sqrt(screen_distance² + (punto - rendija)²)\n",
    "dist_A = np.sqrt(screen_distance**2 + (screen_points - slit_A)**2)\n",
    "dist_B = np.sqrt(screen_distance**2 + (screen_points - slit_B)**2)\n",
    "\n",
    "# Modelo cada rendija como una fuente de ondas circulares\n",
    "# La onda es: amplitud * cos(2π * distancia / longitud_de_onda)\n",
    "# Uso números complejos para representar la fase: e^(i * k * d)\n",
    "k = 2 * np.pi / wavelength   # número de onda\n",
    "\n",
    "wave_A = np.exp(1j * k * dist_A) / dist_A   # onda desde Rendija A\n",
    "wave_B = np.exp(1j * k * dist_B) / dist_B   # onda desde Rendija B\n",
    "\n",
    "# Superposición: sumo las dos ondas en cada punto de la pantalla\n",
    "resultant_wave = wave_A + wave_B\n",
    "\n",
    "# La intensidad es proporcional al módulo al cuadrado de la amplitud\n",
    "intensity = np.abs(resultant_wave)**2\n",
    "\n",
    "# Normalizo para que el máximo sea 1 (más fácil de visualizar)\n",
    "intensity = intensity / np.max(intensity)\n",
    "\n",
    "\n",
    "\n",
    "\n",
    "\n",
    "#parte 2\n",
    "# Grafico el patrón de interferencia\n",
    "# Se deben ver franjas alternas de luz y oscuridad\n",
    "plt.figure(figsize=(10, 6))\n",
    "plt.plot(screen_points * 100, intensity, color='darkorange', label='Interference Pattern')\n",
    "\n",
    "# Relleno debajo de la curva para que se vea más bonito\n",
    "plt.fill_between(screen_points * 100, intensity, alpha=0.3, color='darkorange')\n",
    "\n",
    "plt.xlabel('Posición en la pantalla (cm)')\n",
    "plt.ylabel('Intensidad (normalizada)')\n",
    "plt.title('Ejercicio 3 — Simulación de Doble Rendija con Ondas\\nPatrón de interferencia constructiva y destructiva')\n",
    "plt.legend()\n",
    "plt.grid(True, linestyle='--', alpha=0.5)\n",
    "plt.tight_layout()\n",
    "plt.show()\n"
