    "### Excercise 1:\n",
    "\n",
    "1. Write a program to model the behavior of the probabilistic double slit example depicted in the figure.\n",
    "import numpy as np\n",
    "\n",
    "# Voy a modelar el experimento de doble rendija \n",
    "# El sistema tiene 7 nodos:\n",
    "# Construyo la matriz de transición (7x7)\n",
    "M = np.array([\n",
    "    # Gun   SlitA  SlitB  T0  T1  T2  T3\n",
    "    [  0,    0,     0,    0,  0,  0,  0],   # Gun no recibe nada\n",
    "    [1/2,    0,     0,    0,  0,  0,  0],   # SlitA recibe la mitad de la fuente\n",
    "    [1/2,    0,     0,    0,  0,  0,  0],   # SlitB recibe la otra mitad\n",
    "    [  0,  1/3,   1/6,   1,  0,  0,  0],   # Target 0 (más cerca de SlitA)\n",
    "    [  0,  1/3,   1/6,   0,  1,  0,  0],   # Target 1\n",
    "    [  0,  1/6,   1/3,   0,  0,  1,  0],   # Target 2\n",
    "    [  0,  1/6,   1/3,   0,  0,  0,  1],   # Target 3 (más cerca de SlitB)\n",
    "])\n",
    "\n",
    "v0 = np.array([1, 0, 0, 0, 0, 0, 0], dtype=float)\n",
    "v1 = M @ v0\n",
    "print(\"Estado tras el 1er click (Gun → Slits):\", v1)\n",
    "v2 = M @ v1\n",
    "print(\"Estado tras el 2do click (Slits → Targets):\", v2)\n",
    "labels = [\"Target 0\", \"Target 1\", \"Target 2\", \"Target 3\"]\n",
    "probs  = v2[3:]\n",
    "\n",
    "print(\"\\nProbabilidad final en cada target:\")\n",
    "for t, p in zip(labels, probs):\n",
    "    print(f\"  {t}: {p:.4f}\")\n",
    "print(f\"\\n  Suma total: {probs.sum():.2f}  ✓\")\n",
